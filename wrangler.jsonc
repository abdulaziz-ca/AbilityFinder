{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "abilityfinder",
  "main": "src/index.js",
  "compatibility_date": "2026-07-14",
  "compatibility_flags": ["nodejs_compat"],

  // Only ./public is uploaded. The docs (HANDOFF/ROADMAP/DEPLOY/README) and
  // serve.py stay at the repo root and are therefore never served publicly.
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "not_found_handling": "404-page"
  },

  "observability": { "enabled": true },

  // Caps /api/ask abuse. The API key is the owner's, so an unmetered public
  // endpoint is a direct billing risk. period must be 10 or 60.
  "ratelimits": [
    {
      "name": "ASK_LIMIT",
      "namespace_id": "1001",
      "simple": { "limit": 8, "period": 60 }
    }
  ]

  // ANTHROPIC_API_KEY is a secret, never a var:
  //   npx wrangler secret put ANTHROPIC_API_KEY
}
